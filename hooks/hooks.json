{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "User",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/oujiajian/.claude/plugins/ou-jiajian/claude-voice/hooks/voice-toggle.js\"",
            "async": true,
            "timeout": 5
          }
        ],
        "description": "Voice: toggle on/off when user types /voice or /语音"
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/oujiajian/.claude/plugins/ou-jiajian/claude-voice/hooks/voicesay.js\" \"SessionStart\"",
            "async": true,
            "timeout": 35
          }
        ],
        "description": "Voice: announce welcome when session starts"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|Bash|Read|Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/oujiajian/.claude/plugins/ou-jiajian/claude-voice/hooks/voicesay.js\" \"PostToolUse\"",
            "async": true,
            "timeout": 25
          }
        ],
        "description": "Voice: narrate tool use + completion phrase"
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/oujiajian/.claude/plugins/ou-jiajian/claude-voice/hooks/voicesay.js\" \"SessionEnd\"",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "Voice: say goodbye when session ends"
      }
    ]
  }
}
